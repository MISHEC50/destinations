rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // רק משתמשים מחוברים יכולים לקרוא ולכתוב קבצים
    match /uploads/{teacherName}/{fileName} {
      allow read:  if request.auth != null;
      // כל מורה מחוברת יכולה להעלות לתיקייה שלה, עד 10MB
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
